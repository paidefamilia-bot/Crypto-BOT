# 🌙 Moon Dev's Environment Variables
# Copy this file to .env and fill in your actual API keys

# DeepSeek AI API (for market analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Bybit Exchange API (for trading)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Birdeye API (for market data - existing functionality)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Solana (for existing functionality)
SOLANA_PRIVATE_KEY=your_solana_private_key_here
RPC_ENDPOINT=your_solana_rpc_endpoint_here

# Legacy Anthropic (if you want to use the original agent)
ANTHROPIC_KEY=your_anthropic_key_here

# 🛡️ SECURITY NOTES:
# - Never commit your .env file to version control
# - Use API keys with limited permissions
# - Set appropriate trading limits on your Bybit account
# - Test with small amounts first!